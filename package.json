{
  "name": "dang-quang-watch",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:ping": "tsx scripts/db-ping.ts",
    "db:seed": "tsx scripts/seed-products.ts",
    "db:verify": "tsx scripts/db-verify.ts",
    "db:products": "tsx scripts/db-products-report.ts",
    "db:studio": "prisma studio",
    "admin:create": "tsx scripts/create-admin.ts",
    "test:auth": "tsx scripts/auth-smoke.ts",
    "test:orders": "tsx scripts/orders-smoke.ts",
    "test:products": "tsx scripts/products-smoke.ts",
    "test:users": "tsx scripts/users-smoke.ts",
    "test:routes": "tsx scripts/routes-smoke.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.395.0",
    "motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-alpha.12",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.21.3",
    "prisma": "6.19.3",
    "tailwindcss": "^4.0.0-alpha.12",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
